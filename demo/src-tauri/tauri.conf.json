{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "react-iztro",
  "version": "../package.json",
  "identifier": "com.iztro.ai",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "紫微斗数AI解读",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "installMode": "both",
        "languages": ["SimpChinese", "English"],
        "customLanguageFiles": {
          "SimpChinese": "../nsis-simpchinese.nsh"
        }
      }
    },
    "resources": []
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://ghproxy.net/https://github.com/jingrongx/react-iztro/releases/latest/download/latest.json",
        "https://github.com/jingrongx/react-iztro/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg0MDU1RjY4QUU3RDRCN0YKUldSL1MzMnVhRjhGaERNU01pNUF0bmFIK21PZGlGYkJrcnlBZjRrRlYyRCtXanlyZmxqaWdaM1IK"
    }
  }
}
